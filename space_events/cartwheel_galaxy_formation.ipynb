   "source": [
    "# Cartwheel Galaxy Collision — Improved Educational Shorts Video\n",
    "\n",
    "This notebook creates a **vertical educational MP4 video** about the Cartwheel Galaxy collision.\n",
    "\n",
    "The video is designed for kids to read directly:\n",
    "- clearer galaxy collision animation\n",
    "- a smaller galaxy visibly passing through\n",
    "- expanding gravity ripple/ring\n",
    "- brighter star-forming ring and spokes\n",
    "- simple science facts on screen\n",
    "\n",
    "**Outputs:** `cartwheel_galaxy_collision_improved.mp4` and `cartwheel_galaxy_collision_improved_preview.png`\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8a6b3f62",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Uncomment in a fresh environment if needed:\n",
    "# %pip install -U numpy pillow imageio imageio-ffmpeg\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "39f33e6e",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "from __future__ import annotations\n",
    "\n",
    "from pathlib import Path\n",
    "import math\n",
    "import textwrap\n",
    "import numpy as np\n",
    "from PIL import Image, ImageDraw, ImageFont, ImageFilter\n",
    "import imageio.v2 as imageio\n",
    "from IPython.display import display, Video\n",
    "\n",
    "# =====================================================\n",
    "# Video settings\n",
    "# =====================================================\n",
    "OUT_DIR = Path('.')\n",
    "VIDEO_FILE = OUT_DIR / 'cartwheel_galaxy_collision_improved.mp4'\n",
    "PREVIEW_FILE = OUT_DIR / 'cartwheel_galaxy_collision_improved_preview.png'\n",
    "\n",
    "W, H = 720, 1280          # vertical 9:16 Shorts format\n",
    "FPS = 20\n",
    "SECONDS = 17.0            # 15+ seconds\n",
    "NFRAMES = int(FPS * SECONDS)\n",
    "\n",
    "TITLE = 'Galaxy Collision'\n",
    "SUBTITLE = 'How the Cartwheel Galaxy got its ring'\n",
    "\n",
    "FACTS = [\n",
    "    'A smaller galaxy passed through a bigger galaxy.',\n",
    "    'Gravity pushed gas and dust outward like a ripple in water.',\n",
    "    'That ripple formed a bright ring where many new stars were born.',\n",
    "    'Galaxies are mostly empty space, so most stars do not crash into each other.',\n",
    "    'Galaxy collisions can reshape galaxies and create amazing new structures.',\n",
    "]\n",
    "\n",
    "# Set to True for a very quick test render.\n",
    "# Set back to False for the final full video.\n",
    "FAST_TEST = False\n",
    "\n",
    "if FAST_TEST:\n",
    "    FPS = 12\n",
    "    SECONDS = 5.0\n",
    "    NFRAMES = int(FPS * SECONDS)\n",
    "\n",
    "# =====================================================\n",
    "# Helpers\n",
    "# =====================================================\n",
    "def clamp(x, a=0.0, b=1.0):\n",
    "    return max(a, min(b, x))\n",
    "\n",
    "\n",
    "def ease(x):\n",
    "    x = clamp(x)\n",
    "    return x * x * (3 - 2 * x)\n",
    "\n",
    "\n",
    "def lerp(a, b, t):\n",
    "    return a + (b - a) * t\n",
    "\n",
    "\n",
    "def font(size, bold=False):\n",
    "    paths = [\n",
    "        '/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf' if bold else '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf',\n",
    "        '/usr/share/fonts/truetype/liberation2/LiberationSans-Bold.ttf' if bold else '/usr/share/fonts/truetype/liberation2/LiberationSans-Regular.ttf',\n",
    "    ]\n",
    "    for p in paths:\n",
    "        if Path(p).exists():\n",
    "            return ImageFont.truetype(p, size)\n",
    "    return ImageFont.load_default()\n",
    "\n",
    "\n",
    "FONT_TITLE = font(58, True)\n",
    "FONT_SUBTITLE = font(28, True)\n",
    "FONT_FACT = font(26, True)\n",
    "FONT_SMALL = font(19, True)\n",
    "FONT_NUM = font(48, True)\n",
    "FONT_RECAP = font(22, True)\n",
    "\n",
    "YY, XX = np.indices((H, W))\n",
    "\n",
    "\n",
    "def np_to_img(arr):\n",
    "    return Image.fromarray(np.clip(arr, 0, 255).astype(np.uint8), 'RGB')\n",
    "\n",
    "\n",
    "def draw_glow(arr, cx, cy, radius, color, strength, squash_y=1.0):\n",
    "    r2 = ((XX - cx) ** 2 + ((YY - cy) / squash_y) ** 2) / max(1.0, radius ** 2)\n",
    "    glow = np.exp(-r2 * 3.2) * strength\n",
    "    arr += glow[..., None] * np.array(color, dtype=np.float32)\n",
    "    return arr\n",
    "\n",
    "\n",
    "def make_background(seed=12):\n",
    "    rng = np.random.default_rng(seed)\n",
    "    arr = np.zeros((H, W, 3), dtype=np.float32)\n",
    "\n",
    "    # dark blue space gradient\n",
    "    arr[..., 0] = 4 + 8 * (YY / H)\n",
    "    arr[..., 1] = 7 + 10 * (YY / H)\n",
    "    arr[..., 2] = 22 + 30 * (1 - YY / H)\n",
    "\n",
    "    # nebula clouds\n",
    "    arr = draw_glow(arr, 110, 430, 360, (95, 25, 150), 0.35, 0.65)\n",
    "    arr = draw_glow(arr, 620, 380, 430, (35, 100, 210), 0.28, 0.80)\n",
    "    arr = draw_glow(arr, 480, 840, 420, (150, 35, 115), 0.18, 0.70)\n",
    "\n",
    "    # starfield\n",
    "    stars = 2600\n",
    "    xs = rng.integers(0, W, stars)\n",
    "    ys = rng.integers(0, H, stars)\n",
    "    b = rng.uniform(60, 255, stars)\n",
    "    arr[ys, xs, 0] += b * rng.uniform(0.75, 1.08, stars)\n",
    "    arr[ys, xs, 1] += b * rng.uniform(0.82, 1.10, stars)\n",
    "    arr[ys, xs, 2] += b * rng.uniform(0.95, 1.35, stars)\n",
    "\n",
    "    return np.clip(arr, 0, 255)\n",
    "\n",
    "\n",
    "BASE_BACKGROUND = make_background()\n",
    "\n",
    "# Fixed starburst knot angles so the ring looks stable, not random/flickery.\n",
    "KNOT_RNG = np.random.default_rng(2026)\n",
    "KNOTS = []\n",
    "for k in range(64):\n",
    "    angle = 2 * math.pi * k / 64 + KNOT_RNG.normal(0, 0.035)\n",
    "    radius_offset = KNOT_RNG.normal(0, 10)\n",
    "    size = KNOT_RNG.uniform(10, 23)\n",
    "    kind = 'blue' if k % 3 else 'pink'\n",
    "    twinkle = KNOT_RNG.uniform(0, 2 * math.pi)\n",
    "    KNOTS.append((angle, radius_offset, size, kind, twinkle))\n",
    "\n",
    "\n",
    "def draw_spiral_galaxy(arr, cx, cy, scale=82, angle=0.0, intensity=1.0, blue=False):\n",
    "    ca, sa = math.cos(angle), math.sin(angle)\n",
    "    x = (XX - cx) * ca + (YY - cy) * sa\n",
    "    y = (-(XX - cx) * sa + (YY - cy) * ca) / 0.58\n",
    "    r = np.sqrt(x * x + y * y) / max(1, scale)\n",
    "    th = np.arctan2(y, x)\n",
    "\n",
    "    disk = np.exp(-r * 2.5)\n",
    "    arms = (0.5 + 0.5 * np.cos(2.35 * th - 4.8 * r)) ** 2\n",
    "    arms *= np.exp(-((r - 1.0) ** 2) / 1.1)\n",
    "    core = np.exp(-(r ** 2) / 0.13)\n",
    "\n",
    "    if blue:\n",
    "        disk_c = np.array([90, 145, 255], dtype=np.float32)\n",
    "        arm_c = np.array([120, 215, 255], dtype=np.float32)\n",
    "        core_c = np.array([255, 225, 155], dtype=np.float32)\n",
    "    else:\n",
    "        disk_c = np.array([250, 170, 95], dtype=np.float32)\n",
    "        arm_c = np.array([255, 120, 85], dtype=np.float32)\n",
    "        core_c = np.array([255, 238, 190], dtype=np.float32)\n",
    "\n",
    "    arr += disk[..., None] * disk_c * 0.30 * intensity\n",
    "    arr += arms[..., None] * arm_c * 0.58 * intensity\n",
    "    arr += core[..., None] * core_c * 1.10 * intensity\n",
    "    return arr\n",
    "\n",
    "\n",
    "def draw_cartwheel_collision(arr, p):\n",
    "    # Main Cartwheel galaxy position\n",
    "    gx, gy = W * 0.55, H * 0.54\n",
    "    ellipse_y = 0.78\n",
    "\n",
    "    # The visible collision wave expands through the video.\n",
    "    wave_t = ease((p - 0.16) / 0.56)\n",
    "    ring_radius = lerp(80, 285, wave_t)\n",
    "    final_ring_alpha = ease((p - 0.38) / 0.36)\n",
    "\n",
    "    r = np.sqrt((XX - gx) ** 2 + ((YY - gy) / ellipse_y) ** 2)\n",
    "    theta = np.arctan2((YY - gy) / ellipse_y, XX - gx)\n",
    "\n",
    "    # Soft pre-collision disk\n",
    "    pre_disk = np.exp(-(r ** 2) / (2 * 175 ** 2)) * (1 - 0.45 * final_ring_alpha)\n",
    "    arr[..., 0] += pre_disk * 85\n",
    "    arr[..., 1] += pre_disk * 72\n",
    "    arr[..., 2] += pre_disk * 135\n",
    "\n",
    "    # Expanding bright ring/ripple\n",
    "    ring = np.exp(-((r - ring_radius) ** 2) / (2 * 15 ** 2))\n",
    "    ring_wide = np.exp(-((r - ring_radius) ** 2) / (2 * 39 ** 2))\n",
    "\n",
    "    # Blue-white ring plus pink nebula pockets\n",
    "    nebula_variation = (0.5 + 0.5 * np.sin(9 * theta + 0.022 * r + 4 * p)) ** 2\n",
    "    ring_strength = 0.25 + 0.95 * wave_t\n",
    "    arr[..., 0] += ring * 220 * ring_strength + ring_wide * nebula_variation * 110 * final_ring_alpha\n",
    "    arr[..., 1] += ring * 130 * ring_strength + ring_wide * 70 * final_ring_alpha\n",
    "    arr[..., 2] += ring * 255 * ring_strength + ring_wide * 185 * final_ring_alpha\n",
    "\n",
    "    arr[..., 0] += ring_wide * nebula_variation * 120 * final_ring_alpha\n",
    "    arr[..., 1] += ring_wide * nebula_variation * 35 * final_ring_alpha\n",
    "    arr[..., 2] += ring_wide * nebula_variation * 95 * final_ring_alpha\n",
    "\n",
    "    # Spokes: important Cartwheel visual feature\n",
    "    spoke_t = ease((p - 0.32) / 0.38)\n",
    "    spokes = (0.5 + 0.5 * np.cos(17 * theta + 0.018 * r - 1.2 * p)) ** 4\n",
    "    spokes *= np.exp(-((r - ring_radius * 0.65) ** 2) / (2 * 95 ** 2))\n",
    "    spokes *= (r > 75) & (r < max(100, ring_radius - 10))\n",
    "    arr[..., 0] += spokes * 70 * spoke_t\n",
    "    arr[..., 1] += spokes * 120 * spoke_t\n",
    "    arr[..., 2] += spokes * 235 * spoke_t\n",
    "\n",
    "    # Bright inner core and small spiral remnant\n",
    "    core = np.exp(-(r ** 2) / (2 * 62 ** 2))\n",
    "    arr[..., 0] += core * 180\n",
    "    arr[..., 1] += core * 150\n",
    "    arr[..., 2] += core * 105\n",
    "    arr = draw_spiral_galaxy(arr, gx + 6, gy + 12, 82, -0.28 + 0.4 * p, 0.55, blue=False)\n",
    "\n",
    "    # Star-forming knots on the expanding ring\n",
    "    knot_alpha = ease((p - 0.42) / 0.34)\n",
    "    for ang, roff, size, kind, tw in KNOTS:\n",
    "        rr = ring_radius + roff\n",
    "        sx = gx + rr * math.cos(ang)\n",
    "        sy = gy + ellipse_y * rr * math.sin(ang)\n",
    "        flicker = 0.75 + 0.25 * math.sin(2 * math.pi * p * 3 + tw)\n",
    "        if kind == 'blue':\n",
    "            col = (80, 205, 255)\n",
    "        else:\n",
    "            col = (255, 95, 170)\n",
    "        arr = draw_glow(arr, sx, sy, size, col, 0.44 * knot_alpha * flicker)\n",
    "\n",
    "    # Smaller galaxy path: lower-left -> through center -> upper-right\n",
    "    move = ease((p - 0.05) / 0.60)\n",
    "    start = np.array([95.0, 900.0])\n",
    "    through = np.array([gx - 28, gy + 5])\n",
    "    end = np.array([615.0, 500.0])\n",
    "    if move < 0.58:\n",
    "        q = ease(move / 0.58)\n",
    "        pos = start * (1 - q) + through * q\n",
    "    else:\n",
    "        q = ease((move - 0.58) / 0.42)\n",
    "        pos = through * (1 - q) + end * q\n",
    "    ix, iy = pos\n",
    "\n",
    "    # Tidal trail / bridge left by the intruder\n",
    "    trail_t = ease((p - 0.18) / 0.40)\n",
    "    # distance to line segment from start to current position, approximated with a thick glowing curve drawn later too\n",
    "    vx, vy = ix - start[0], iy - start[1]\n",
    "    denom = max(1.0, vx * vx + vy * vy)\n",
    "    u = np.clip(((XX - start[0]) * vx + (YY - start[1]) * vy) / denom, 0, 1)\n",
    "    px = start[0] + u * vx\n",
    "    py = start[1] + u * vy\n",
    "    dist = np.sqrt((XX - px) ** 2 + (YY - py) ** 2)\n",
    "    trail = np.exp(-(dist ** 2) / (2 * 22 ** 2)) * trail_t\n",
    "    arr[..., 0] += trail * 150\n",
    "    arr[..., 1] += trail * 80\n",
    "    arr[..., 2] += trail * 210\n",
    "\n",
    "    # Intruder galaxy is easier to see before/after crossing.\n",
    "    intruder_alpha = 1.20 - 0.18 * np.exp(-((move - 0.58) ** 2) / 0.01)\n",
    "    arr = draw_glow(arr, ix, iy, 95, (255, 135, 65), 0.18 * intruder_alpha)\n",
    "    arr = draw_spiral_galaxy(arr, ix, iy, 70, -0.75 + 1.5 * p, intruder_alpha, blue=False)\n",
    "\n",
    "    # shock flash at collision moment\n",
    "    flash = np.exp(-((p - 0.39) ** 2) / (2 * 0.025 ** 2))\n",
    "    arr = draw_glow(arr, gx, gy, 170, (255, 245, 190), flash * 0.8)\n",
    "\n",
    "    return arr, (gx, gy, ring_radius), (ix, iy)\n",
    "\n",
    "\n",
    "def centered_text(draw, xy, text, fnt, fill, stroke_fill=(0, 0, 0, 220), stroke_width=2):\n",
    "    draw.text(xy, text, anchor='mm', font=fnt, fill=fill, stroke_width=stroke_width, stroke_fill=stroke_fill)\n",
    "\n",
    "\n",
    "def draw_wrapped_text(draw, xy, text, fnt, fill, width_chars, anchor='lm', spacing=6, stroke_width=2):\n",
    "    wrapped = textwrap.fill(text, width=width_chars)\n",
    "    draw.text(xy, wrapped, anchor=anchor, font=fnt, fill=fill, spacing=spacing, stroke_width=stroke_width, stroke_fill=(0, 0, 0, 230))\n",
    "\n",
    "\n",
    "def fact_index_for_progress(p):\n",
    "    # 5 kid-readable facts spread across the video.\n",
    "    if p < 0.14:\n",
    "        return None\n",
    "    return min(4, int(clamp((p - 0.14) / 0.80) * 5))\n",
    "\n",
    "\n",
    "def draw_overlays(img, p, ring_info, intruder_pos):\n",
    "    d = ImageDraw.Draw(img, 'RGBA')\n",
    "\n",
    "    # Top title plate\n",
    "    d.rounded_rectangle((28, 28, W - 28, 142), radius=24, fill=(0, 0, 24, 175), outline=(100, 165, 255, 170), width=3)\n",
    "    centered_text(d, (W // 2, 70), TITLE, FONT_TITLE, (235, 248, 255, 255), (20, 65, 160, 255), 3)\n",
    "    centered_text(d, (W // 2, 119), SUBTITLE, FONT_SUBTITLE, (255, 226, 90, 255), (0, 0, 0, 220), 2)\n",
    "\n",
    "    # Clean labels for the two objects.\n",
    "    gx, gy, rr = ring_info\n",
    "    ix, iy = intruder_pos\n",
    "    label_alpha = int(190 * ease((p - 0.12) / 0.25))\n",
    "    if label_alpha > 0:\n",
    "        d.rounded_rectangle((448, 860, 675, 900), radius=16, fill=(0, 9, 34, label_alpha), outline=(120, 220, 255, label_alpha), width=2)\n",
    "        d.text((561, 880), 'Cartwheel Galaxy', anchor='mm', font=FONT_SMALL, fill=(210, 240, 255, 255))\n",
    "\n",
    "        # Keep the smaller-galaxy label close to the moving intruder, so the collision is obvious.\n",
    "        lx = int(clamp(ix, 130, W - 130))\n",
    "        ly = int(clamp(iy + 82, 210, 955))\n",
    "        d.line((int(ix), int(iy), lx, ly - 22), fill=(255, 200, 95, label_alpha), width=2)\n",
    "        d.rounded_rectangle((lx - 112, ly - 20, lx + 112, ly + 20), radius=16, fill=(0, 9, 34, label_alpha), outline=(255, 190, 90, label_alpha), width=2)\n",
    "        d.text((lx, ly), 'smaller galaxy', anchor='mm', font=FONT_SMALL, fill=(255, 225, 175, 255))\n",
    "\n",
    "    # Ripple callout during ring expansion.\n",
    "    ripple_alpha = int(190 * ease((p - 0.32) / 0.18) * (1 - ease((p - 0.58) / 0.15)))\n",
    "    if ripple_alpha > 0:\n",
    "        d.rounded_rectangle((72, 190, 648, 252), radius=20, fill=(0, 8, 32, ripple_alpha), outline=(70, 200, 255, ripple_alpha), width=3)\n",
    "        d.text((360, 221), 'Gravity ripple spreading outward', anchor='mm', font=FONT_SMALL, fill=(220, 245, 255, 255))\n",
    "\n",
    "    # Bottom educational fact card\n",
    "    stage = fact_index_for_progress(p)\n",
    "    y1, y2 = 1018, 1242\n",
    "    if stage is None:\n",
    "        d.rounded_rectangle((40, y1, W - 40, y2), radius=26, fill=(0, 8, 32, 200), outline=(95, 155, 255, 220), width=4)\n",
    "        centered_text(d, (W // 2, y1 + 72), 'A collision can make a ring galaxy.', FONT_FACT, (255, 255, 255, 255))\n",
    "        centered_text(d, (W // 2, y1 + 132), 'Watch the smaller galaxy pass through.', FONT_SMALL, (210, 235, 255, 255), stroke_width=1)\n",
    "    elif stage == 'recap':\n",
    "        d.rounded_rectangle((32, 978, W - 32, 1250), radius=26, fill=(0, 8, 32, 215), outline=(255, 190, 80, 230), width=4)\n",
    "        centered_text(d, (W // 2, 1016), 'What happened?', FONT_FACT, (255, 229, 100, 255))\n",
    "        yy = 1052\n",
    "        for i, fact in enumerate(FACTS, start=1):\n",
    "            d.rounded_rectangle((58, yy - 11, 92, yy + 23), radius=8, fill=(255, 145, 35, 190))\n",
    "            d.text((75, yy + 6), str(i), anchor='mm', font=font(22, True), fill=(255, 255, 255, 255))\n",
    "            draw_wrapped_text(d, (108, yy + 6), fact, FONT_RECAP, (255, 255, 255, 255), width_chars=45, anchor='lm', spacing=2, stroke_width=1)\n",
    "            yy += 39\n",
    "    else:\n",
    "        i = min(4, max(0, int(stage)))\n",
    "        colors = [(160, 80, 255), (55, 150, 255), (35, 215, 230), (90, 220, 95), (255, 145, 35)]\n",
    "        col = colors[i]\n",
    "        d.rounded_rectangle((40, y1, W - 40, y2), radius=26, fill=(0, 8, 32, 215), outline=(*col, 235), width=5)\n",
    "        d.rounded_rectangle((66, y1 + 42, 150, y1 + 126), radius=18, fill=(*col, 120), outline=(*col, 235), width=2)\n",
    "        d.text((108, y1 + 84), str(i + 1), anchor='mm', font=FONT_NUM, fill=(255, 255, 255, 255), stroke_width=2, stroke_fill=(*col, 240))\n",
    "        draw_wrapped_text(d, (174, y1 + 84), FACTS[i], FONT_FACT, (255, 255, 255, 255), width_chars=28, anchor='lm')\n",
    "\n",
    "    return img\n",
    "\n",
    "\n",
    "def render_frame(frame_i):\n",
    "    p = frame_i / max(1, NFRAMES - 1)\n",
    "\n",
    "    # Slight cinematic zoom-in over time.\n",
    "    arr = BASE_BACKGROUND.copy()\n",
    "    arr, ring_info, intruder_pos = draw_cartwheel_collision(arr, p)\n",
    "\n",
    "    # Mild vignette helps text and galaxy pop.\n",
    "    cx, cy = W / 2, H / 2\n",
    "    vignette = 1 - 0.42 * np.clip(np.sqrt(((XX - cx) / cx) ** 2 + ((YY - cy) / cy) ** 2), 0, 1) ** 1.7\n",
    "    arr *= vignette[..., None]\n",
    "\n",
    "    img = np_to_img(arr).filter(ImageFilter.GaussianBlur(0.15)).convert('RGBA')\n",
    "\n",
    "    # Add a few drawn sparkle crosses after conversion for crispness.\n",
    "    d = ImageDraw.Draw(img, 'RGBA')\n",
    "    rng = np.random.default_rng(8000 + frame_i // 3)\n",
    "    for _ in range(6):\n",
    "        x = int(rng.integers(20, W - 20))\n",
    "        y = int(rng.integers(160, 980))\n",
    "        a = int(rng.integers(90, 160))\n",
    "        r = int(rng.integers(2, 5))\n",
    "        d.line((x - r * 3, y, x + r * 3, y), fill=(225, 240, 255, a), width=1)\n",
    "        d.line((x, y - r * 3, x, y + r * 3), fill=(225, 240, 255, a), width=1)\n",
    "\n",
    "    img = draw_overlays(img, p, ring_info, intruder_pos)\n",
    "\n",
    "    # Very slight sharpen near the end for a cleaner final look.\n",
    "    if p > 0.55:\n",
    "        img = img.filter(ImageFilter.SHARPEN)\n",
    "    return img.convert('RGB')\n",
    "\n",
    "\n",
    "def render_video(video_path=VIDEO_FILE, preview_path=PREVIEW_FILE):\n",
    "    preview = render_frame(int(NFRAMES * 0.72))\n",
    "    preview.save(preview_path, quality=95)\n",
    "\n",
    "    writer = imageio.get_writer(\n",
    "        video_path,\n",
    "        fps=FPS,\n",
    "        codec='libx264',\n",
    "        quality=8,\n",
    "        macro_block_size=1,\n",
